#: afcutils.cpp:60
#, kde-format
msgid "Unhandled AFC error code '%1'"
msgstr "Cod de eroare AFC neprevăzut „%1”"

#: afcutils.cpp:73
#, kde-format
msgid "Unhandled housearrest error code '%1'"
msgstr "Cod de eroare „housearrest” neprevăzut „%1”"

#: afcutils.cpp:89
#, kde-format
msgid "Unhandled instproxy error code '%1'"
msgstr "Cod de eroare „instproxy” neprevăzut „%1”"

#: afcutils.cpp:105
#, kde-format
msgid ""
"The device is locked. Please enter the passcode on the device and try again."
msgstr ""
"Dispozitivul e blocat. Introduceți codul de acces pe dispozitiv și încercați "
"din nou."

#: afcutils.cpp:112
#, kde-format
msgid "You have denied this computer access to the device."
msgstr "Ați refuzat accesul acestui calculator la dispozitiv."

#: afcutils.cpp:119
#, kde-format
msgid ""
"You need to allow this computer to access the device. Please accept the "
"prompt on the device and try again."
msgstr ""
"Trebuie să permiteți acestui calculator să acceseze dispozitivul. Acceptați "
"solicitarea pe dispozitiv și încercați din nou."

#: afcutils.cpp:127
#, kde-format
msgid ""
"Cannot access the device. Make sure it is unlocked and allows this computer "
"to access it."
msgstr ""
"Dispozitivul nu poate fi accesat. Asigurați-vă că e deblocat și că permite "
"acestui calculator să-l acceseze."

#: afcutils.cpp:134
#, kde-format
msgid "Unhandled lockdownd code '%1'"
msgstr "Cod „lockdownd” neprevăzut „%1”"

#: afcutils.cpp:147
#, kde-format
msgid "Unhandled sbservices code '%1'"
msgstr "Cod „sbservices” neprevăzut „%1”"

#: kio_afc.cpp:134
#, kde-format
msgid "Apple Devices"
msgstr "Dispozitive Apple"

#: kio_afc.cpp:181 kio_afc.cpp:402
#, kde-format
msgctxt "Link to folder with files stored inside apps"
msgid "Apps"
msgstr "Aplicații"

#: kio_afc.cpp:606
#, kde-format
msgid "Cannot read without opening file first"
msgstr "Nu se poate citi fără a deschide mai întâi fișierul"

#: kio_afc.cpp:626
#, kde-format
msgid "Cannot seek without opening file first"
msgstr "Nu se poate derula fără a deschide mai întâi fișierul"

#: kio_afc.cpp:654
#, kde-format
msgid "Cannot write without opening file first"
msgstr "Nu se poate scrie fără a deschide mai întâi fișierul"

#: kio_afc.cpp:806
#, kde-format
msgid "Cannot rename between devices."
msgstr "Nu se poate redenumi între dispozitive."
