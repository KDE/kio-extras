msgstr "Nezpracovaný chybový instproxy kód '%1'"

#: afcutils.cpp:105
#, kde-format
msgid ""
"The device is locked. Please enter the passcode on the device and try again."
msgstr ""
"Zařízení je zamčeno. Zadejte prosím přístupový kód zařízení a zkuste to "
"znovu."

#: afcutils.cpp:112
#, kde-format
msgid "You have denied this computer access to the device."
msgstr "Váš přístup počítače k zařízení byl odmítnut."

#: afcutils.cpp:119
#, kde-format
msgid ""
"You need to allow this computer to access the device. Please accept the "
"prompt on the device and try again."
msgstr ""
"Pro přístup k tomuto zařízení je nutné tomuto počítači povolit přístup. "
"Přijměte prosím výzvu k tomuto zařízení a zkuste to znovu."

#: afcutils.cpp:127
#, kde-format
msgid ""
"Cannot access the device. Make sure it is unlocked and allows this computer "
"to access it."
msgstr ""
"Nelze přistupovat k zařízení. Ujistěte se, že je odemčené a umožňuje tomuto "
"počítači k sobě přístup."

#: afcutils.cpp:134
#, kde-format
msgid "Unhandled lockdownd code '%1'"
msgstr "Nezpracovaný chybový lockdownd kód '%1'"

#: afcutils.cpp:147
#, kde-format
msgid "Unhandled sbservices code '%1'"
msgstr "Nezpracovaný chybový sbservices kód '%1'"

#: kio_afc.cpp:134
#, kde-format
msgid "Apple Devices"
msgstr "Zařízení Apple"

#: kio_afc.cpp:181 kio_afc.cpp:402
#, kde-format
msgctxt "Link to folder with files stored inside apps"
msgid "Apps"
msgstr "Aplikace"

#: kio_afc.cpp:606
#, kde-format
msgid "Cannot read without opening file first"
msgstr "Nelze přečíst dokud není nejprve soubor otevřený"

#: kio_afc.cpp:626
#, kde-format
msgid "Cannot seek without opening file first"
msgstr "Nelze vyhledávat dokud není nejprve soubor otevřený"

#: kio_afc.cpp:654
#, kde-format
msgid "Cannot write without opening file first"
msgstr "Nelze zapisovat dokud není nejprve soubor otevřený"

#: kio_afc.cpp:806
#, kde-format
msgid "Cannot rename between devices."
msgstr "Nelze přejmenovávat mezi zařízeními."
