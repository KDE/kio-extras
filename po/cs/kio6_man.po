#: kio_man.cpp:495
#, kde-kuit-format
msgctxt "@info"
msgid ""
"No man page matching <resource>%1</resource> could be found.<nl/><nl/>Check "
"that you have not mistyped the name of the page, and note that man page "
"names are case sensitive.<nl/><nl/>If the name is correct, then you may need "
"to extend the search path for man pages, either using the <envar>MANPATH</"
"envar> environment variable or a configuration file in the <filename>/etc</"
"filename> directory."
msgstr ""
"Nebyla nalezena žádná manuálová stránka odpovídající <resource>%1</resource>."
"<nl/><nl/>Zkontrolujte, zda jste nezadali název stránky nesprávně. Berte na "
"vědomí, že názvy manuálových stránek jsou citlivé na velikost písmen.<nl/"
"><nl/>Pokud je název správný, možná budete muset rozšířit cestu hledání "
"manuálových stránek pomocí proměnné prostředí <envar>MANPATH</envar> nebo "
"konfiguračního souboru v adresáři <filename>/etc</filename>."

#: kio_man.cpp:610
#, kde-kuit-format
msgctxt "@info"
msgid ""
"The specified man page references another page <filename>%1</filename>,<nl/"
">but the referenced page <filename>%2</filename> could not be found."
msgstr ""
"Zadaná manuálová stránka odkazuje na jinou stránku <filename>%1</filename>,"
"<nl/> ale odkazovaná stránka <filename>%2</filename> nebyla nalezena."

#: kio_man.cpp:627
#, kde-kuit-format
msgctxt "@info"
msgid "The man page <filename>%1</filename> could not be read."
msgstr "Manuálovou stránku <filename>%1</filename> nelze přečíst."

#: kio_man.cpp:636
#, kde-kuit-format
msgctxt "@info"
msgid "The man page <filename>%1</filename> could not be converted."
msgstr "Manuálovou stránku <filename>%1</filename> nelze převézt."

