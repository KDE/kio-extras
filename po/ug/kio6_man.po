#: kio_man.cpp:495
#, kde-kuit-format
msgctxt "@info"
msgid ""
"No man page matching <resource>%1</resource> could be found.<nl/><nl/>Check "
"that you have not mistyped the name of the page, and note that man page "
"names are case sensitive.<nl/><nl/>If the name is correct, then you may need "
"to extend the search path for man pages, either using the <envar>MANPATH</"
"envar> environment variable or a configuration file in the <filename>/etc</"
"filename> directory."
msgstr ""
"<resource>%1</resource> نىڭ قوللانما بېتىنى تاپالمىدى.<nl/><nl/>بەت ئىسمىنى "
"خاتا كىرگۈزمىگەنلىكىڭىزنى جەزملەڭ ۋە قوللانما بېتىنىڭ ئىسمى چوڭ كىچىك ھەرپنى "
"پەرقلەندۈرىدىغانلىقىغا دىققەت قىلىڭ.<nl/><nl/>ئەگەر ئىسىم توغرا بولسا، "
"ئۇنداقتا قوللانما بېتىنىڭ ئىزدەش يولىنى كېڭەيتىڭ ياكى <envar>MANPATH</envar> "
"مۇھىم ئۆزگەرگۈچىسىنى ئىشلىتىڭ ياكى <filename>/etc</filename> مۇندەرىجىسىدە "
"سەپلىمە ھۆججەت قۇرۇڭ."

#: kio_man.cpp:610
#, kde-kuit-format
msgctxt "@info"
msgid ""
"The specified man page references another page <filename>%1</filename>,<nl/"
">but the referenced page <filename>%2</filename> could not be found."
msgstr ""
"بەلگىلەنگەن قوللانما بېتى يەنە بىر بەت <filename>%1</filename> نى نەقىل "
"ئالغان،<nl/>ئەمما نەقىل بەت <filename>%2</filename> نى تاپالمىدى."

#: kio_man.cpp:627
#, kde-kuit-format
msgctxt "@info"
msgid "The man page <filename>%1</filename> could not be read."
msgstr "بۇ قوللانما بېتى <filename>%1</filename> نى ئوقۇيالمايدۇ."

#: kio_man.cpp:636
#, kde-kuit-format
msgctxt "@info"
msgid "The man page <filename>%1</filename> could not be converted."
msgstr "بۇ قوللانما بېتى <filename>%1</filename> نى ئايلاندۇرالمايدۇ."

