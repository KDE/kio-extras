#: kio_mtp.cpp:221
#, kde-format
msgctxt ""
"Message shown when attempting to access an MTP device that is not fully "
"accessible yet"
msgid ""
"Could not access device. Make sure it is unlocked, and tap \"Allow\" on the "
"popup on its screen. If that does not work, make sure MTP is enabled in its "
"USB connection settings."
msgstr ""

#: kio_mtp.cpp:520
#, kde-format
msgid "Cannot copy/move files on the device itself"
msgstr "ئۈسكۈنىنىڭ ئۆزىدە ھۆججەتنى كۆچۈرۈپ/يۆتكىيەلمەيدۇ"
