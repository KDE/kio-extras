#: kio_man.cpp:495
#, fuzzy, kde-kuit-format
#| msgid ""
#| "No man page matching to %1 found.<br /><br />Check that you have not "
#| "mistyped the name of the page that you want.<br />Check that you have "
#| "typed the name using the correct upper and lower case characters.<br />If "
#| "everything looks correct, then you may need to improve the search path "
#| "for man pages; either using the environment variable MANPATH or using a "
#| "matching file in the /etc directory."
msgctxt "@info"
msgid ""
"No man page matching <resource>%1</resource> could be found.<nl/><nl/>Check "
"that you have not mistyped the name of the page, and note that man page "
"names are case sensitive.<nl/><nl/>If the name is correct, then you may need "
"to extend the search path for man pages, either using the <envar>MANPATH</"
"envar> environment variable or a configuration file in the <filename>/etc</"
"filename> directory."
msgstr ""
"бһҡбһҖвҖӢбһҳбһ·бһ“вҖӢбһғбһҫбһүвҖӢбһ‘бҹҶбһ–бҹҗбһҡ man бһҠбҹӮбһӣвҖӢвҖӢбһ•бҹ’бһӮбһјбһ•бҹ’бһӮбһ„вҖӢбһ“бһ№бһ„вҖӢ %1 бһЎбһҫбһҷВ бҹ”<br/><br/>бһҹбһјбһҳвҖӢбһ–бһ·бһ“бһ·бһҸбҹ’бһҷвҖӢбһҳбһҫбһӣвҖӢбһҗбһ¶ бһўбҹ’бһ“бһҖвҖӢбһҳбһ·бһ“вҖӢбһ”бһ¶бһ“вҖӢбһңбһ¶бһҷвҖӢбһҒбһ»бһҹвҖӢбһҲбҹ’бһҳбҹ„бҹҮвҖӢбһҡбһ”бһҹбҹӢвҖӢ"
"бһ‘бҹҶбһ–бҹҗбһҡвҖӢбһҠбҹӮбһӣвҖӢбһўбҹ’бһ“бһҖвҖӢбһ…бһ„бҹӢвҖӢбһҡбһҖвҖӢбһ‘бҹҒВ бҹ”<br/>бһ–бһ·бһ“бһ·бһҸбҹ’бһҷвҖӢбһҳбһҫбһӣбһҗбһ¶ бһўбҹ’бһ“бһҖвҖӢбһ”бһ¶бһ“вҖӢбһңбһ¶бһҷвҖӢбһҲбҹ’бһҳбҹ„бҹҮвҖӢбһҠбҹ„бһҷбһ”бҹ’бһҡбһҫвҖӢбһҸбһҪбһўбһҖбҹ’бһҹбһҡвҖӢбһ’бҹҶбһҸбһјбһ…вҖӢбһҸбҹ’бһҡбһ№бһҳбһҸбҹ’бһҡбһјбһңВ бҹ” <br/> бһ”бһҫвҖӢвҖӢ"
"бһўбҹ’бһңбһёбҹ—вҖӢбһҸбҹ’бһҡбһ№бһҳвҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ бһҫбһҷ бһ“бҹ„бҹҮвҖӢбһ”бҹ’бһҡбһ бҹӮбһӣвҖӢбһҮбһ¶вҖӢбһўбҹ’бһ“бһҖвҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһҮбһҳбҹ’бһҡбһ»бһүвҖӢбһ•бҹ’бһӣбһјбһңвҖӢбһҹбҹ’бһңбҹӮбһ„вҖӢбһҡбһҖвҖӢбһҠбҹҸвҖӢбһ”бҹ’бһҡбһҹбһҫбһҡвҖӢбһҮбһ¶бһ„вҖӢбһҳбһҪбһҷвҖӢбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢвҖӢбһ‘бҹҶбһ–бҹҗбһҡвҖӢвҖӢбһҹбҹҖбһңбһ—бҹ…вҖӢбһҠбҹғВ бҹ” бһҖбҹҶбһҺбһҸбҹӢвҖӢбһңбһ¶вҖӢ"
"бһҠбҹ„бһҷвҖӢбһ”бҹ’бһҡбһҫвҖӢбһўбһҗбҹҒбһҡвҖӢбһ”бһҡбһ·бһҹбҹ’бһҗбһ¶бһ“ MANPATH бһ¬вҖӢбһҜбһҖбһҹбһ¶бһҡвҖӢбһҠбҹӮбһӣвҖӢбһҠбһјбһ…вҖӢбһҖбҹ’бһ“бһ»бһ„вҖӢбһҗбһҸ /etcВ бҹ”"

